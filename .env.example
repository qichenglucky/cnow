# CodeNow Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env

# ── Database ──────────────────────────────────────────────
CNOW_DB_HOST=localhost
CNOW_DB_PORT=5432
CNOW_DB_USER=cnow
CNOW_DB_PASSWORD=cnow
CNOW_DB_NAME=cnow
CNOW_DB_SSLMODE=disable

# ── HTTP Server ───────────────────────────────────────────
CNOW_HTTP_ADDR=:8080

# ── Environment ───────────────────────────────────────────
# dev | staging | production
CNOW_ENV=dev

# ── Temporal ──────────────────────────────────────────────
CNOW_TEMPORAL_HOST=localhost:7233
CNOW_TEMPORAL_NAMESPACE=default

# ── Redis ─────────────────────────────────────────────────
CNOW_REDIS_ADDR=localhost:6379
CNOW_REDIS_PASSWORD=

# ── Proxy (optional, for external resources) ──────────────
# https_proxy=http://127.0.0.1:1087
# http_proxy=http://127.0.0.1:1087
